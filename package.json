{
  "name": "daylight",
  "version": "0.2.0",
  "private": true,
  "description": "A public, observational watchdog for federal .gov infrastructure. Public data only, observational only.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "typecheck": "pnpm -r --parallel typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "pnpm --filter @daylight/web dev",
    "build": "pnpm --filter @daylight/web build",
    "start": "pnpm --filter @daylight/web start",
    "ledger": "pnpm --filter @daylight/ledger start",
    "ledger:seed": "pnpm --filter @daylight/ledger seed",
    "ledger:history": "pnpm --filter @daylight/ledger history",
    "ledger:backfill-first-seen": "pnpm --filter @daylight/ledger backfill-first-seen",
    "receipts:audit-archives": "pnpm --filter @daylight/receipts audit-archives",
    "analytics:reset": "pnpm --filter @daylight/db reset:analytics",
    "ci": "pnpm typecheck && pnpm test",
    "redtape:assess": "pnpm --filter @daylight/redtape assess",
    "foundry": "pnpm --filter @daylight/foundry scan",
    "sitescanning": "pnpm --filter @daylight/sitescanning start",
    "sitescanning:seed": "pnpm --filter @daylight/sitescanning seed",
    "github": "pnpm --filter @daylight/github start",
    "github:seed": "pnpm --filter @daylight/github seed"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "sharp"
    ]
  }
}
