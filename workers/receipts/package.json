{
  "name": "@daylight/receipts",
  "version": "0.5.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./sweep": {
      "types": "./src/sweep.ts",
      "default": "./src/sweep.ts"
    }
  },
  "types": "./src/index.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "snapshot": "tsx src/cli.ts",
    "audit-archives": "tsx src/audit-archives-cli.ts"
  },
  "dependencies": {
    "@daylight/core": "workspace:*",
    "@daylight/db": "workspace:*",
    "@daylight/feeds": "workspace:*",
    "@daylight/fingerprints": "workspace:*",
    "@daylight/redact": "workspace:*",
    "@daylight/floodlight": "workspace:*"
  }
}
