# Daylight — environment variables. Copy to .env for local dev (.env is gitignored).
# In production these are set on the host (Fly: non-secrets in fly.toml [env],
# secrets via `fly secrets set`). NOTHING here is required for the site to boot.

# --- Core (safe, non-secret) ---
# Public origin, no trailing slash. Feeds/canonical URLs use this; in prod it must be set
# so those URLs aren't derived from a client-supplied Host header.
DAYLIGHT_SITE_URL=http://localhost:3000
# Where the SQLite file lives. In prod this is a mounted volume path (/data/daylight.db).
DAYLIGHT_DB_PATH=./data/daylight.db
# Daily in-process Ledger cron (UTC). Unset to disable the scheduler.
DAYLIGHT_LEDGER_CRON=17 0 * * *

# --- Feature flags (non-secret; "1" enables) ---
FLAG_LEDGER_REGISTRY=1
FLAG_LEDGER_FEED=1
FLAG_LEDGER_HEURISTICS=1
FLAG_LOOKOUT=1
FLAG_FLOODLIGHT=1
FLAG_RECEIPTS=1
FLAG_REDTAPE=1
# Live page capture (spawns a headless browser). Leave OFF in prod until a network egress
# filter (drop RFC1918/link-local/loopback) is enforced on the machine — see SECURITY notes.
# FLAG_FLOODLIGHT_SCAN=1
# First-party, aggregate-only analytics shown on /privacy (no IP/UA/cookie stored). Leave OFF in
# local dev so the dev server doesn't write hit rows; set to 1 in prod (fly.toml sets it there).
# FLAG_ANALYTICS=1

# --- Secrets (set only where needed; never commit real values) ---
# Gate for the internal /review queue. Unset ⇒ /review returns 404 (feature off).
# DAYLIGHT_REVIEW_TOKEN=
# Enables the Redtape research agent (deferred; the pipeline + human gate work without it).
# ANTHROPIC_API_KEY=
# DAYLIGHT_REDTAPE_MODEL=claude-sonnet-5
# Raises the GitHub API rate limit for the one-time git-history backfill (optional).
# GITHUB_TOKEN=
