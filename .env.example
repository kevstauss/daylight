# Daylight — environment variables. Copy to .env for local dev (.env is gitignored).
# In production these are set on the host (Fly: non-secrets in fly.toml [env],
# secrets via `fly secrets set`). NOTHING here is required for the site to boot.

# --- Core (safe, non-secret) ---
# Public origin, no trailing slash. Feeds/canonical URLs use this; in prod it must be set
# so those URLs aren't derived from a client-supplied Host header.
DAYLIGHT_SITE_URL=http://localhost:3000
# Where the SQLite file lives. In prod this is a mounted volume path (/data/daylight.db).
DAYLIGHT_DB_PATH=./data/daylight.db
# Daily in-process Ledger cron (UTC). Unset to disable the scheduler.
DAYLIGHT_LEDGER_CRON=17 0 * * *
# Foundry is derived (joins Lookout's CT subdomains + Ledger's registry, fetches nothing), so
# schedule it a beat AFTER the Lookout backfill so it reads fresh certs. Unset to disable.
# DAYLIGHT_FOUNDRY_CRON=45 1 * * *
# Site Scanning breadth net: pull GSA's daily federal-web scan dump, diff it, and promote unwatched
# .gov apexes into the Floodlight sweep when a new tracker appears. Needs GSA_SITE_SCANNING_API_KEY
# (below). Unset to disable. In a free 02:00–02:59 slot so it doesn't collide with other crons.
# DAYLIGHT_SITESCANNING_CRON=10 2 * * *
# GitHub org monitoring: poll watched federal orgs (config/watchlist.yaml github_orgs) for new repos
# + first commits; findings surface as Lookout events. GITHUB_TOKEN (below) is optional but raises
# the rate limit. Unset to disable.
# DAYLIGHT_GITHUB_CRON=30 2 * * *
# Probation window (days) that a brand-new .gov registration stays in the auto-watch tier — the
# sweeps (Floodlight/Receipts/Lookout) scan it alongside the curated + watchlist priorities. Keyed
# on Ledger's `added` change, so a new domain is watched from day one. Default 90.
# DAYLIGHT_NEW_DOMAIN_WATCH_DAYS=90
# Ko-fi handle for the reader-support ask (footer + banner + /methods + /privacy). Defaults to the
# project handle, so the tip picker works out of the box. Set to a different handle to override, or
# to an empty value (DAYLIGHT_KOFI=) to hide the support ask everywhere. No third-party script or
# iframe is loaded — the picker is self-hosted and only links out to Ko-fi's checkout.
# DAYLIGHT_KOFI=kevstauss

# --- Feature flags (non-secret; "1" enables) ---
FLAG_LEDGER_REGISTRY=1
FLAG_LEDGER_FEED=1
FLAG_LEDGER_HEURISTICS=1
FLAG_LOOKOUT=1
FLAG_FOUNDRY=1
FLAG_FLOODLIGHT=1
FLAG_RECEIPTS=1
FLAG_REDTAPE=1
# Site Scanning breadth net (GSA daily scan → Floodlight promotion + corroboration). Gates the
# scheduled ingest and its /status row; not a public tile.
FLAG_SITESCANNING=1
# Federal GitHub org monitoring (new repos / first commits → Lookout events). Gates the scheduled
# poll and its 'github' /status row; not a public tile.
FLAG_GITHUB=1
# Redtape live page reads: lets the AI researcher fetch a site's own privacy page + an agency PIA
# inventory page (guarded — .gov-only, SSRF-checked, robots-respecting, redacted, existence-only at
# any access wall). The Federal-Register + web_search tools work without it; this only adds direct
# .gov page reads. Leave OFF in local dev; enable deliberately in prod.
# FLAG_REDTAPE_FETCH=1
# Live page capture (spawns a headless browser). Leave OFF in prod until a network egress
# filter (drop RFC1918/link-local/loopback) is enforced on the machine — see SECURITY notes.
# FLAG_FLOODLIGHT_SCAN=1
# First-party, aggregate-only analytics shown on /privacy (no IP/UA/cookie stored). Leave OFF in
# local dev so the dev server doesn't write hit rows; set to 1 in prod (fly.toml sets it there).
# FLAG_ANALYTICS=1
# Keep the operator's own visits out of those counts so they don't inflate a low-traffic launch.
# Comma/space-separated list of exact client IPs, or prefixes ending in '.'/':' for a range (e.g.
# "203.0.113.7, 203.0.113., 2001:db8:"). The IP is read transiently to skip recording and is NEVER
# stored/logged (see /privacy). Use the reset CLI to wipe already-recorded hits: `pnpm analytics:reset --yes`.
# DAYLIGHT_ANALYTICS_EXCLUDE_IPS=
# Automated clients (bots, crawlers, AI assistants incl. Claude Code) are dropped from the counts by
# a built-in User-Agent list; the UA is read transiently and never stored. Optionally add more
# substrings here (comma/space-separated, case-insensitive, appended to the built-ins). Generic HTTP
# tools (curl/python/wget) are deliberately NOT built in, so real API/feed consumers still count.
# DAYLIGHT_ANALYTICS_EXCLUDE_UA=

# --- Secrets (set only where needed; never commit real values) ---
# Gate for the internal /review queue. Unset ⇒ /review returns 404 (feature off).
# DAYLIGHT_REVIEW_TOKEN=
# Enables the Redtape research agent (deferred; the pipeline + human gate work without it).
# ANTHROPIC_API_KEY=
# DAYLIGHT_REDTAPE_MODEL=claude-sonnet-5
# Raises the GitHub API rate limit for the one-time git-history backfill (optional).
# GITHUB_TOKEN=
# Free api.data.gov key for the GSA Site Scanning bulk dump (get one at https://api.data.gov/signup/).
# The Site Scanning cron skips cleanly if unset. DEMO_KEY works for a throttled manual test only.
# GSA_SITE_SCANNING_API_KEY=
